#pragma once
// secrets.h.example - Copy to secrets.h and fill in your Wi-Fi credentials

#define WIFI_SSID "your-wifi-ssid"  // Wi-Fi name (case-sensitive!)
#define WIFI_PASS "your-wifi-password"

// IP address or hostname of the machine running the bridge service
#define BRIDGE_HOST "192.168.1.100"
#define BRIDGE_PORT 8787

// Optional. If you start the bridge with BRIDGE_TOKEN=..., put the same value here.
// Leave empty for a trusted private LAN.
#define BRIDGE_TOKEN ""
